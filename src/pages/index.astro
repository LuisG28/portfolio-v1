      <a href="https://github.com/LuisG28" target="_blank" class="nav-link" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #9fb0d8; text-decoration: none;">GitHub</a>
      <a href="https://www.linkedin.com/in/luis-gustavo-cruz-rosales-1383351a1/" target="_blank" class="nav-link" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #9fb0d8; text-decoration: none;">LinkedIn</a>
    </div>
  </footer>

</div>

<script is:inline>
  let currentLang = 'es';
  let menuOpen = false;

  function setLang(lang) {
    currentLang = lang;
    document.querySelectorAll('[data-es][data-en]').forEach(el => {
      el.textContent = el.dataset[lang];
    });
    const cvLink = document.getElementById('cv-link');
    if (cvLink) cvLink.href = lang === 'en' ? cvLink.dataset.cvEn : cvLink.dataset.cvEs;
    updateLangButtons();
  }

  function updateLangButtons() {
    const active = 'padding: 6px 14px; border-radius: 100px; border: none; cursor: pointer; font-family: JetBrains Mono, monospace; font-size: 12px; background: linear-gradient(135deg, #0B51FF, #12DEFF); color: #020921; font-weight: 600; transition: all 0.2s;';
    const inactive = 'padding: 6px 14px; border-radius: 100px; border: none; cursor: pointer; font-family: JetBrains Mono, monospace; font-size: 12px; background: transparent; color: #9fb0d8; transition: all 0.2s;';
    document.getElementById('btn-es').style.cssText = currentLang === 'es' ? active : inactive;
    document.getElementById('btn-en').style.cssText = currentLang === 'en' ? active : inactive;
  }

  function toggleMenu() {
    menuOpen = !menuOpen;
    const menu = document.getElementById('mobile-menu');
    menu.style.display = menuOpen ? 'flex' : 'none';
  }

  function closeMenu() {
    menuOpen = false;
    document.getElementById('mobile-menu').style.display = 'none';
  }

  // Responsive: hamburger vs desktop nav
  const mql = window.matchMedia('(max-width: 760px)');
  function onMQ(e) {
    const btn = document.getElementById('menu-btn');
    const nav = document.getElementById('desktop-nav');
    if (e.matches) {
      btn.style.display = 'flex';
      nav.style.display = 'none';
    } else {
      btn.style.display = 'none';
      nav.style.display = 'flex';
      closeMenu();
    }
  }
  if (mql.addEventListener) mql.addEventListener('change', onMQ);
  else mql.addListener(onMQ);
  onMQ(mql);

  // Scroll reveal
  function reveal(el) {
    el.classList.add('revealed');
    el.style.transitionDelay = '';
  }

  function setupReveal() {
    const vh = window.innerHeight || 800;
    document.querySelectorAll('[data-reveal]').forEach((el, i) => {
      if (el.dataset.revealReady) return;
      el.dataset.revealReady = '1';
      el.style.transitionDelay = ((i % 6) * 0.07) + 's';
      if (el.getBoundingClientRect().top < vh * 0.95) {
        requestAnimationFrame(() => reveal(el));
      }
    });
  }

  const revealObs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) reveal(e.target); });
  }, { threshold: 0.12 });

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-reveal]').forEach(el => revealObs.observe(el));
    setupReveal();

    // Fallback: reveal all after 1.2s
    setTimeout(() => {
      document.querySelectorAll('[data-reveal]').forEach(el => reveal(el));
    }, 1200);

    setupTimeline();
  });

  window.addEventListener('scroll', () => {
    const vh = window.innerHeight || 800;
    document.querySelectorAll('[data-reveal]').forEach(el => {
      if (!el.classList.contains('revealed') && el.getBoundingClientRect().top < vh * 0.9) {
        reveal(el);
      }
    });
  }, { passive: true });

  // Timeline animation
  function setupTimeline() {
    const timeline = document.getElementById('timeline');
    if (!timeline) return;
    const tlObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const line = document.getElementById('tl-line');
        if (line) line.style.animation = 'drawline 1s cubic-bezier(.2,.7,.2,1) forwards';
        document.querySelectorAll('.tl-dot').forEach((dot, i) => {
          dot.style.animation = 'dotpop 0.5s cubic-bezier(.2,1.4,.4,1) forwards';
          dot.style.animationDelay = (0.25 + i * 0.22) + 's';
        });
        tlObs.disconnect();
      });
    }, { threshold: 0.25 });
    tlObs.observe(timeline);
  }
</script>
</body>
</html>
