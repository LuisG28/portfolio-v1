---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const portfolioPreview = `${base}/portfolio-preview.png`;
const cvEs = `${base}/CV_LuisGustavoCruz_ES.pdf`;
const cvEn = `${base}/CV_LuisGustavoCruz_EN.pdf`;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Luis Gustavo Cruz Rosales — Full Stack Developer</title>
  <meta name="description" content="Portfolio de Luis Gustavo Cruz Rosales, Full Stack Developer con más de 3 años de experiencia." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Sora:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background: #020921;
      color: #eaf0ff;
      font-family: 'Sora', sans-serif;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    ::selection { background: #12DEFF; color: #020921; }

    @keyframes floaty {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50% { transform: translate(40px, -30px) scale(1.08); }
    }
    @keyframes floaty2 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50% { transform: translate(-50px, 40px) scale(1.12); }
    }
    @keyframes gridmove {
      from { background-position: 0 0; }
      to { background-position: 0 60px; }
    }
    @keyframes gradshift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    @keyframes pulsering {
      0% { transform: scale(0.9); opacity: 0.7; }
      70% { transform: scale(1.25); opacity: 0; }
      100% { opacity: 0; }
    }
    @keyframes blink {
      0%, 49% { opacity: 1; }
      50%, 100% { opacity: 0; }
    }
    @keyframes slidedown {
      from { opacity: 0; transform: translateY(-12px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes drawline {
      from { transform: scaleY(0); }
      to { transform: scaleY(1); }
    }
    @keyframes dotpop {
      0% { transform: scale(0); }
      60% { transform: scale(1.35); }
      100% { transform: scale(1); }
    }
    @keyframes dotring {
      0% { transform: scale(0.8); opacity: 0.6; }
      70% { transform: scale(2.1); opacity: 0; }
      100% { opacity: 0; }
    }

    [data-reveal] {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.7s cubic-bezier(.2,.7,.2,1), transform 0.7s cubic-bezier(.2,.7,.2,1);
    }
    [data-reveal].revealed {
      opacity: 1;
      transform: translateY(0);
    }

    .card-hover { transition: transform 0.3s ease, border-color 0.3s ease !important; }
    .card-hover:hover { transform: translateY(-6px) !important; border-color: rgba(18,222,255,0.4) !important; }

    .skill-hover { transition: all 0.3s ease !important; }
    .skill-hover:hover {
      border-color: rgba(18,222,255,0.45) !important;
      background: rgba(18,222,255,0.06) !important;
      transform: translateY(-4px) !important;
    }

    .cta-hover { transition: transform 0.25s ease, box-shadow 0.25s ease !important; }
    .cta-hover:hover { transform: translateY(-3px) !important; box-shadow: 0 12px 40px rgba(18,222,255,0.55) !important; }

    .social-hover { transition: all 0.25s ease !important; }
    .social-hover:hover {
      border-color: #12DEFF !important;
      color: #12DEFF !important;
      background: rgba(18,222,255,0.08) !important;
      transform: translateY(-3px) !important;
    }

    .repo-hover { transition: all 0.25s ease !important; }
    .repo-hover:hover {
      background: rgba(85,255,158,0.1) !important;
      box-shadow: 0 0 24px rgba(85,255,158,0.25) !important;
    }

    .nav-link { transition: color 0.25s ease; }
    .nav-link:hover { color: #12DEFF !important; }

    #mobile-menu { animation: slidedown 0.25s ease; }
  </style>
</head>
<body>
<div id="root" style="position: relative; min-height: 100vh; width: 100%; overflow: hidden;">

  <!-- Animated background -->
  <div style="position: fixed; inset: 0; z-index: 0; pointer-events: none;">
    <div style="position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(11,81,255,0.22), transparent 70%), radial-gradient(ellipse 50% 50% at 90% 110%, rgba(85,255,158,0.10), transparent 70%);"></div>
    <div style="position: absolute; inset: -2px; background-image: linear-gradient(rgba(18,222,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(18,222,255,0.05) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse 70% 80% at 50% 20%, #000 30%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse 70% 80% at 50% 20%, #000 30%, transparent 80%); animation: gridmove 12s linear infinite;"></div>
    <div style="position: absolute; top: 8%; left: -6%; width: 460px; height: 460px; border-radius: 50%; background: radial-gradient(circle, rgba(11,81,255,0.5), transparent 65%); filter: blur(50px); animation: floaty 16s ease-in-out infinite;"></div>
    <div style="position: absolute; bottom: 2%; right: -8%; width: 420px; height: 420px; border-radius: 50%; background: radial-gradient(circle, rgba(18,222,255,0.35), transparent 65%); filter: blur(60px); animation: floaty2 20s ease-in-out infinite;"></div>
  </div>

  <!-- NAV -->
  <nav style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; backdrop-filter: blur(14px); background: rgba(2,9,33,0.6); border-bottom: 1px solid rgba(18,222,255,0.10);">
    <div style="display: flex; align-items: center; justify-content: space-between; padding: 16px clamp(20px, 6vw, 80px);">
      <a href="#home" style="display: flex; align-items: center; gap: 10px; text-decoration: none; color: #eaf0ff;">
        <span style="display: grid; place-items: center; width: 38px; height: 38px; border-radius: 11px; background: linear-gradient(135deg, #0B51FF, #12DEFF); font-family: 'Space Grotesk', sans-serif; font-weight: 700; color: #020921; font-size: 14px; box-shadow: 0 0 20px rgba(18,222,255,0.45);">LG</span>
        <span style="font-family: 'Space Grotesk', sans-serif; font-weight: 600; letter-spacing: 0.5px;">Luis G.</span>
      </a>

      <div style="display: flex; align-items: center; gap: clamp(14px, 2.2vw, 30px);">
        <div id="desktop-nav" style="display: flex; align-items: center; gap: clamp(14px, 2.2vw, 30px);">
          <a href="#home" class="nav-link" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #9fb0d8; text-decoration: none; letter-spacing: 0.3px;" data-es="01. Inicio" data-en="01. Home">01. Inicio</a>
          <a href="#about" class="nav-link" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #9fb0d8; text-decoration: none; letter-spacing: 0.3px;" data-es="02. Sobre mí" data-en="02. About">02. Sobre mí</a>
          <a href="#projects" class="nav-link" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #9fb0d8; text-decoration: none; letter-spacing: 0.3px;" data-es="03. Proyectos" data-en="03. Projects">03. Proyectos</a>
          <a href="#skills" class="nav-link" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #9fb0d8; text-decoration: none; letter-spacing: 0.3px;" data-es="04. Skills" data-en="04. Skills">04. Skills</a>
          <a href="#experience" class="nav-link" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #9fb0d8; text-decoration: none; letter-spacing: 0.3px;" data-es="05. Experiencia" data-en="05. Experience">05. Experiencia</a>
          <a href="#contact" class="nav-link" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #9fb0d8; text-decoration: none; letter-spacing: 0.3px;" data-es="06. Contacto" data-en="06. Contact">06. Contacto</a>
        </div>

        <!-- Language toggle -->
        <div style="display: flex; align-items: center; padding: 4px; border-radius: 100px; border: 1px solid rgba(18,222,255,0.2); background: rgba(255,255,255,0.02); font-family: 'JetBrains Mono', monospace; font-size: 12px;">
          <button id="btn-es" onclick="setLang('es')" style="padding: 6px 14px; border-radius: 100px; border: none; cursor: pointer; font-family: 'JetBrains Mono', monospace; font-size: 12px; background: linear-gradient(135deg, #0B51FF, #12DEFF); color: #020921; font-weight: 600; transition: all 0.2s;">ES</button>
          <button id="btn-en" onclick="setLang('en')" style="padding: 6px 14px; border-radius: 100px; border: none; cursor: pointer; font-family: 'JetBrains Mono', monospace; font-size: 12px; background: transparent; color: #9fb0d8; transition: all 0.2s;">EN</button>
        </div>

        <!-- Hamburger (mobile) -->
        <button id="menu-btn" onclick="toggleMenu()" aria-label="Menu" style="display: none; padding: 10px; background: transparent; border: 1px solid rgba(18,222,255,0.2); border-radius: 10px; cursor: pointer; flex-direction: column; gap: 5px;">
          <span style="width: 20px; height: 2px; background: #12DEFF; border-radius: 2px; display: block;"></span>
          <span style="width: 20px; height: 2px; background: #12DEFF; border-radius: 2px; display: block;"></span>
          <span style="width: 20px; height: 2px; background: #12DEFF; border-radius: 2px; display: block;"></span>
        </button>
      </div>
    </div>

    <!-- Mobile dropdown -->
    <div id="mobile-menu" style="display: none; flex-direction: column; padding: 8px clamp(20px, 6vw, 80px) 20px; border-top: 1px solid rgba(18,222,255,0.08);">
      <a href="#home" onclick="closeMenu()" style="padding: 13px 4px; font-family: 'JetBrains Mono', monospace; font-size: 14px; color: #c7d4f5; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,0.05);" data-es="01. Inicio" data-en="01. Home">01. Inicio</a>
      <a href="#about" onclick="closeMenu()" style="padding: 13px 4px; font-family: 'JetBrains Mono', monospace; font-size: 14px; color: #c7d4f5; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,0.05);" data-es="02. Sobre mí" data-en="02. About">02. Sobre mí</a>
      <a href="#projects" onclick="closeMenu()" style="padding: 13px 4px; font-family: 'JetBrains Mono', monospace; font-size: 14px; color: #c7d4f5; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,0.05);" data-es="03. Proyectos" data-en="03. Projects">03. Proyectos</a>
      <a href="#skills" onclick="closeMenu()" style="padding: 13px 4px; font-family: 'JetBrains Mono', monospace; font-size: 14px; color: #c7d4f5; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,0.05);" data-es="04. Skills" data-en="04. Skills">04. Skills</a>
      <a href="#experience" onclick="closeMenu()" style="padding: 13px 4px; font-family: 'JetBrains Mono', monospace; font-size: 14px; color: #c7d4f5; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,0.05);" data-es="05. Experiencia" data-en="05. Experience">05. Experiencia</a>
      <a href="#contact" onclick="closeMenu()" style="padding: 13px 4px; font-family: 'JetBrains Mono', monospace; font-size: 14px; color: #c7d4f5; text-decoration: none;" data-es="06. Contacto" data-en="06. Contact">06. Contacto</a>
    </div>
  </nav>

  <!-- HERO -->
  <section id="home" style="position: relative; z-index: 1; min-height: 100vh; display: flex; align-items: center; padding: 120px clamp(20px, 6vw, 80px) 80px; gap: clamp(30px, 6vw, 90px); flex-wrap: wrap;">
    <div style="flex: 1 1 460px; max-width: 660px;">
      <div data-reveal style="display: inline-flex; align-items: center; gap: 8px; padding: 7px 16px; border-radius: 100px; border: 1px solid rgba(85,255,158,0.3); background: rgba(85,255,158,0.06); font-family: 'JetBrains Mono', monospace; font-size: 12.5px; color: #55FF9E; margin-bottom: 26px;">
        <span style="width: 7px; height: 7px; border-radius: 50%; background: #55FF9E; box-shadow: 0 0 10px #55FF9E; flex-shrink: 0;"></span>
        <span data-es="Disponible para nuevos proyectos" data-en="Available for new projects">Disponible para nuevos proyectos</span>
      </div>
      <p data-reveal style="font-family: 'JetBrains Mono', monospace; color: #12DEFF; font-size: 15px; margin: 0 0 10px;">
        <span data-es="Hola, soy" data-en="Hi, I'm">Hola, soy</span>
      </p>
      <h1 data-reveal style="font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: clamp(44px, 7vw, 82px); line-height: 1.02; margin: 0 0 18px; letter-spacing: -1.5px;">
        Luis Gustavo<br>
        <span style="background: linear-gradient(110deg, #0B51FF, #12DEFF, #55FF9E, #12DEFF); background-size: 250% auto; -webkit-background-clip: text; background-clip: text; color: transparent; animation: gradshift 6s ease-in-out infinite;">Cruz Rosales</span>
      </h1>
      <div data-reveal style="display: flex; align-items: center; gap: 12px; font-family: 'Space Grotesk', sans-serif; font-size: clamp(20px, 3vw, 28px); color: #c7d4f5; margin-bottom: 26px;">
        <span style="width: 36px; height: 2px; background: linear-gradient(90deg, #12DEFF, transparent); flex-shrink: 0;"></span>
        Full Stack Developer<span style="color: #12DEFF; animation: blink 1.1s step-end infinite;">_</span>
      </div>
      <p data-reveal style="font-size: 17px; line-height: 1.7; color: #9fb0d8; max-width: 520px; margin: 0 0 36px;"
         data-es="Desarrollador full stack con más de 3 años construyendo aplicaciones web y móviles rápidas, accesibles y bien diseñadas."
         data-en="Full stack developer with 3+ years building fast, accessible and well-designed web and mobile applications.">
        Desarrollador full stack con más de 3 años construyendo aplicaciones web y móviles rápidas, accesibles y bien diseñadas.
      </p>
      <div data-reveal style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
        <a id="cv-link" href={cvEs} data-cv-es={cvEs} data-cv-en={cvEn} download target="_blank" class="cta-hover" style="display: inline-flex; align-items: center; gap: 9px; padding: 14px 26px; border-radius: 12px; background: linear-gradient(135deg, #0B51FF, #12DEFF); color: #020921; font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 15px; text-decoration: none; box-shadow: 0 8px 30px rgba(18,222,255,0.35);">
          <span data-es="Descargar CV" data-en="Download CV">Descargar CV</span> →
        </a>
        <div style="display: flex; gap: 10px;">
          <a href="https://github.com/LuisG28" target="_blank" title="GitHub" class="social-hover" style="display: grid; place-items: center; width: 48px; height: 48px; border-radius: 12px; border: 1px solid rgba(18,222,255,0.2); background: rgba(255,255,255,0.02); color: #c7d4f5; text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 12px;">GH</a>
          <a href="https://www.linkedin.com/in/luis-gustavo-cruz-rosales-1383351a1/" target="_blank" title="LinkedIn" class="social-hover" style="display: grid; place-items: center; width: 48px; height: 48px; border-radius: 12px; border: 1px solid rgba(18,222,255,0.2); background: rgba(255,255,255,0.02); color: #c7d4f5; text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 12px;">in</a>
        </div>
      </div>
    </div>

    <!-- Avatar -->
    <div data-reveal style="flex: 0 1 360px; display: grid; place-items: center; position: relative; min-width: 280px;">
      <div style="position: absolute; width: 320px; height: 320px; border-radius: 50%; border: 1px solid rgba(18,222,255,0.4); animation: pulsering 3.5s ease-out infinite;"></div>
      <div style="position: absolute; width: 320px; height: 320px; border-radius: 50%; border: 1px solid rgba(85,255,158,0.3); animation: pulsering 3.5s ease-out infinite 1.2s;"></div>
      <div style="position: relative; width: clamp(240px, 30vw, 320px); height: clamp(240px, 30vw, 320px); border-radius: 50%; box-shadow: 0 0 60px rgba(11,81,255,0.45);">
        <div style="position: absolute; inset: 0; border-radius: 50%; background: conic-gradient(from 0deg, #0B51FF, #12DEFF, #55FF9E, #0B51FF);"></div>
        <div style="position: absolute; inset: 4px; border-radius: 50%; background: #020921; padding: 6px;">
          <img src="https://luisg28.github.io/portfolio-v1/avatar.webp" alt="Luis Gustavo" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; display: block;">
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" style="position: relative; z-index: 1; padding: 90px clamp(20px, 6vw, 80px); max-width: 1200px; margin: 0 auto;">
    <div data-reveal style="font-family: 'JetBrains Mono', monospace; color: #12DEFF; font-size: 14px; margin-bottom: 12px;"
         data-es="// sobre mí" data-en="// about me">// sobre mí</div>
    <h2 data-reveal style="font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: clamp(32px, 5vw, 52px); margin: 0 0 40px; letter-spacing: -1px;"
        data-es="Un poco sobre quién soy" data-en="A bit about who I am">Un poco sobre quién soy</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px;">
      <div data-reveal class="card-hover" style="padding: 26px; border-radius: 18px; border: 1px solid rgba(18,222,255,0.12); background: linear-gradient(160deg, rgba(18,222,255,0.04), rgba(11,81,255,0.02));">
        <div style="width: 32px; height: 3px; border-radius: 2px; background: linear-gradient(90deg, #12DEFF, #55FF9E); margin-bottom: 18px;"></div>
        <p style="margin: 0; font-size: 15px; line-height: 1.6; color: #b8c6ea;"
           data-es="Más de 3 años trabajando como desarrollador full stack, del front al back."
           data-en="Over 3 years working as a full stack developer, from front to back.">
          Más de 3 años trabajando como desarrollador full stack, del front al back.
        </p>
      </div>
      <div data-reveal class="card-hover" style="padding: 26px; border-radius: 18px; border: 1px solid rgba(18,222,255,0.12); background: linear-gradient(160deg, rgba(18,222,255,0.04), rgba(11,81,255,0.02));">
        <div style="width: 32px; height: 3px; border-radius: 2px; background: linear-gradient(90deg, #12DEFF, #55FF9E); margin-bottom: 18px;"></div>
        <p style="margin: 0; font-size: 15px; line-height: 1.6; color: #b8c6ea;"
           data-es="Egresado en Tecnologías de la Información y Comunicación por la UT de Xicotepec de Juárez."
           data-en="Graduate in Information and Communication Technologies from UT of Xicotepec de Juárez.">
          Egresado en Tecnologías de la Información y Comunicación por la UT de Xicotepec de Juárez.
        </p>
      </div>
      <div data-reveal class="card-hover" style="padding: 26px; border-radius: 18px; border: 1px solid rgba(18,222,255,0.12); background: linear-gradient(160deg, rgba(18,222,255,0.04), rgba(11,81,255,0.02));">
        <div style="width: 32px; height: 3px; border-radius: 2px; background: linear-gradient(90deg, #12DEFF, #55FF9E); margin-bottom: 18px;"></div>
        <p style="margin: 0; font-size: 15px; line-height: 1.6; color: #b8c6ea;"
           data-es="Apasionado por el desarrollo de aplicaciones web y móviles con foco en la experiencia."
           data-en="Passionate about building web and mobile applications with a focus on experience.">
          Apasionado por el desarrollo de aplicaciones web y móviles con foco en la experiencia.
        </p>
      </div>
      <div data-reveal class="card-hover" style="padding: 26px; border-radius: 18px; border: 1px solid rgba(18,222,255,0.12); background: linear-gradient(160deg, rgba(18,222,255,0.04), rgba(11,81,255,0.02));">
        <div style="width: 32px; height: 3px; border-radius: 2px; background: linear-gradient(90deg, #12DEFF, #55FF9E); margin-bottom: 18px;"></div>
        <p style="margin: 0; font-size: 15px; line-height: 1.6; color: #b8c6ea;"
           data-es="Disponible para proyectos remotos. Me adapto rápido a nuevos stacks y equipos."
           data-en="Available for remote projects. I adapt quickly to new stacks and teams.">
          Disponible para proyectos remotos. Me adapto rápido a nuevos stacks y equipos.
        </p>
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects" style="position: relative; z-index: 1; padding: 90px clamp(20px, 6vw, 80px); max-width: 1200px; margin: 0 auto;">
    <div data-reveal style="font-family: 'JetBrains Mono', monospace; color: #12DEFF; font-size: 14px; margin-bottom: 12px;"
         data-es="// proyectos" data-en="// projects">// proyectos</div>
    <h2 data-reveal style="font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: clamp(32px, 5vw, 52px); margin: 0 0 40px; letter-spacing: -1px;"
        data-es="Trabajo y proyectos" data-en="Work &amp; projects">Trabajo y proyectos</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px;">
      <!-- Featured project -->
      <div data-reveal class="card-hover" style="display: flex; flex-direction: column; border-radius: 24px; overflow: hidden; border: 1px solid rgba(18,222,255,0.15); background: linear-gradient(160deg, rgba(11,81,255,0.06), rgba(2,9,33,0.4)); box-shadow: 0 24px 60px rgba(0,0,0,0.35);">
        <div style="position: relative; height: 210px; overflow: hidden;">
          <img src={portfolioPreview} alt="Portfolio preview" style="width: 100%; height: 100%; object-fit: cover; display: block;">
          <div style="position: absolute; inset: 0; background: linear-gradient(180deg, transparent 45%, rgba(2,9,33,0.75));"></div>
          <span style="position: absolute; top: 14px; left: 14px; padding: 5px 12px; border-radius: 100px; background: rgba(2,9,33,0.7); backdrop-filter: blur(6px); font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #55FF9E; letter-spacing: 0.5px;"
                data-es="PROYECTO DESTACADO" data-en="FEATURED PROJECT">PROYECTO DESTACADO</span>
        </div>
        <div style="padding: 28px; display: flex; flex-direction: column; flex: 1;">
          <h3 style="font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 24px; margin: 0 0 12px;">Portfolio personal</h3>
          <p style="font-size: 15px; line-height: 1.7; color: #9fb0d8; margin: 0 0 20px; flex: 1;"
